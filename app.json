{
  "expo": {
    "name": "ForgeScan",
    "slug": "forgescan-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f7f8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4f7f8"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "ForgeScan uses the camera to capture ordered object frames for local 3D reconstruction projects."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "ForgeScan can open your system camera app to capture high-quality object frames.",
          "microphonePermission": false,
          "photosPermission": false
        }
      ]
    ]
  }
}
