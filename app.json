{
  "expo": {
    "name": "ForgeScan",
    "slug": "forgescan-mobile",
    "version": "0.1.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f7f8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4f7f8"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.forgescanmobile"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "ForgeScan uses the camera for photo, timed burst, and muted video object capture.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "./plugins/withForgeScanNativeEngines"
    ]
  }
}
